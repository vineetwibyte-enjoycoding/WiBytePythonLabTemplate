{
    "name": "WiByte Lab",
    "image": "mcr.microsoft.com/devcontainers/python:3.11",
    "features": {
        "ghcr.io/devcontainers/features/desktop-lite:1": { "version": "latest" }
    },
    "forwardPorts": [6080],
    "customizations": {
        "vscode": {
            "settings": {
    // 1. DISBALE THE GHOST TEXT (Already done)
    "editor.inlineSuggest.enabled": false,
    "github.copilot.editor.enableAutoCompletions": false,
    "github.copilot.inlineSuggest.enable": false,

    // 2. DISABLE THE "FIX IT FOR ME" MECHANIC (The Keep/Undo window)
    // This stops the AI from suggesting fixes directly on the lines of code
    "github.copilot.editor.enableCodeActions": false,
    "github.copilot.chat.editor.enableCodeActions": false,
    
    // 3. DISABLE THE "CMD+I" INLINE CHAT
    // This prevents students from opening a chat bubble inside the code window
    "github.copilot.editor.enableInlineChat": false,

    // 4. THE REPLIT LAYOUT (Keeps it familiar and fast)
    "workbench.panel.defaultLocation": "right"
            }            
        }
    }
}
